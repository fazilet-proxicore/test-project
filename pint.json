{
    "preset": "laravel",
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "not_operator_with_successor_space": false,
        "class_attributes_separation": {
            "elements": {
                "const": "none",
                "method": "one",
                "property": "none",
                "trait_import": "none"
            }
        },
        "no_extra_blank_lines": {
            "tokens": ["extra", "throw", "use"]
        },
        "blank_line_between_import_groups": false,
        "new_with_parentheses": {
            "anonymous_class": false,
            "named_class": true
        },
        "types_spaces": false,
        "phpdoc_align": false
    }
}
